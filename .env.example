# Legalizer Environment Variables Configuration
# Currently, the App runs purely on a Next.js Simulated Context Engine for maximum speed and demo capability.
# If you transition to a real backend, populate these variables.

# Database (e.g., MongoDB / PostgreSQL)
DATABASE_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/legalizer

# Authentication (e.g., NextAuth / JWT)
NEXTAUTH_SECRET=your_super_secret_key_here
NEXTAUTH_URL=http://localhost:3000

# Legal AI APIs (For replacing the local JSON knowledge base)
GEMINI_API_KEY=your_gemini_api_key_here

# Cloud Storage (For replacing the Simulated Evidence Vault)
AWS_S3_BUCKET=legalizer-vault-bucket
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
